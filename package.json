{
  "name": "strapi-plugin-content-manager-organizer",
  "version": "1.0.0",
  "description": "Organize Strapi Content Manager collection types into collapsible grouped sections",
  "license": "MIT",
  "author": {
    "name": "Chetan Hasarmani",
    "url": "https://github.com/chetanhasarmani1724"
  },
  "homepage": "https://github.com/chetanhasarmani1724/strapi-content-manager-organizer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chetanhasarmani1724/strapi-content-manager-organizer.git"
  },
  "bugs": {
    "url": "https://github.com/chetanhasarmani1724/strapi-content-manager-organizer/issues"
  },
  "keywords": [
    "strapi",
    "strapi-plugin",
    "strapi5",
    "content-manager",
    "sidebar",
    "collection-types",
    "organizer",
    "groups"
  ],
  "strapi": {
    "name": "content-manager-organizer",
    "displayName": "Content Manager Organizer",
    "description": "Group Content Manager collection types into collapsible sections",
    "kind": "plugin"
  },
  "main": "./dist/server/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "admin",
    "server",
    "dist",
    "strapi-admin.js",
    "strapi-server.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "verify": "strapi-plugin verify",
    "prepublishOnly": "npm run build && npm run verify"
  },
  "devDependencies": {
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/sdk-plugin": "^5.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@strapi/strapi": "^5.46.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  }
}